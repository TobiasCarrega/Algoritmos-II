import java.util.*;

class Elem {
    int valor;
    int prioridad;

    Elem(int v) {
        valor = v;
        if (v > 0) prioridad = 2;
        else if (v == 0) prioridad = 1;
        else prioridad = 0;
    }
}

public class Desafio5 {

    public static Queue<Elem> clasificar(Queue<Integer> cola) {
        Queue<Elem> resultado = new LinkedList<>();

        while (!cola.isEmpty()) {
            int x = cola.poll();
            resultado.add(new Elem(x));
        }

        return resultado;
    }

    // Simulación de desacolar por prioridad
    public static Elem desacolarPrioridad(Queue<Elem> cola) {
        Elem mayor = null;

        for (Elem e : cola) {
            if (mayor == null || e.prioridad > mayor.prioridad) {
                mayor = e;
            }
        }

        cola.remove(mayor);
        return mayor;
    }
}
