import java.util.*;

public class Desafio1 {

    public static boolean esPalindromo(Queue<Integer> cola) {
        Stack<Integer> pila = new Stack<>();
        Queue<Integer> aux = new LinkedList<>();

        int n = cola.size();

        // Copiar y preparar estructuras
        for (int i = 0; i < n; i++) {
            int x = cola.poll();
            pila.push(x);
            aux.add(x);
            cola.add(x); // restaurar original
        }

        // Comparar
        while (!aux.isEmpty()) {
            if (!aux.poll().equals(pila.pop())) {
                return false;
            }
        }

        return true;
    }
}

-No alcanza una sola pila porque invierte el orden pero no preserva el original para comparar. Necesito una pila para invertir y una cola auxiliar para mantener el orden. Así puedo comparar ambos recorridos sin perder la estructura original

