    import java.util.*;

public class Desafio3 {

    public static boolean esUnica(Stack<Integer> pila) {
        Stack<Integer> aux = new Stack<>();
        Set<Integer> conjunto = new HashSet<>();

        boolean esUnica = true;

        while (!pila.isEmpty()) {
            int x = pila.pop();

            if (conjunto.contains(x)) {
                esUnica = false;
            } else {
                conjunto.add(x);
            }

            aux.push(x);
        }

        // Restaurar pila original
        while (!aux.isEmpty()) {
            pila.push(aux.pop());
        }

        return esUnica;
    }
}
-La pila no permite consultar pertenencia sin desapilar. Uso un conjunto para verificar duplicados y una pila auxiliar para no perder el orden. Recorro desapilando, verifico en el conjunto y luego restauro la pila.


